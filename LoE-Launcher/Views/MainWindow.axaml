<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LoE_Launcher.ViewModels"
        xmlns:models="using:LoE_Launcher.Models"
        xmlns:utils="using:LoE_Launcher.Utils"
        mc:Ignorable="d"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Width="1024" Height="576"
        MinWidth="900" MinHeight="506"
        x:Class="LoE_Launcher.Views.MainWindow"
        Title="LoE Launcher"
        Icon="avares://LoE-Launcher/Assets/Icon.ico"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        FontFamily="Segoe UI, SF Pro Display, Arial, sans-serif">

    <Window.Styles>
        <Style Selector="Button.SocialButton">
            <Setter Property="Width" Value="50" />
            <Setter Property="Height" Value="50" />
            <Setter Property="CornerRadius" Value="25" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="PART_GlassBorder"
                            Background="#601A1028"
                            CornerRadius="25"
                            BorderThickness="1"
                            BorderBrush="#80f0be4a">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.15" />
                                <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.SocialButton:pointerover /template/ Border#PART_GlassBorder">
            <Setter Property="Background" Value="#801A1028" />
            <Setter Property="BorderBrush" Value="#f0be4a" />
        </Style>
        <Style Selector="Button.SocialButton:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.08)" />
        </Style>
        <Style Selector="Button.SocialButton:pressed /template/ Border#PART_GlassBorder">
            <Setter Property="Background" Value="#451A1028" />
            <Setter Property="BorderBrush" Value="#CCf0be4a" />
        </Style>
        <Style Selector="Button.SocialButton:pressed">
            <Setter Property="RenderTransform" Value="scale(0.92)" />
        </Style>

        <Style Selector="Button.SettingsButton">
            <Setter Property="Width" Value="70" />
            <Setter Property="Height" Value="70" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid>
                        <Border x:Name="PART_Border"
                                Background="#781A1028"
                                CornerRadius="35"
                                BorderThickness="1"
                                BorderBrush="#80f0be4a">
                            <Border.Transitions>
                                <Transitions>
                                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                                    <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
                                </Transitions>
                            </Border.Transitions>
                            <Image x:Name="PART_Icon"
                                   Width="36" Height="36"
                                   Source="avares://LoE-Launcher/Assets/Gear.png"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Opacity="0.9">
                                <Image.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.15" />
                                    </Transitions>
                                </Image.Transitions>
                            </Image>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.SettingsButton:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="#981A1028" />
            <Setter Property="BorderBrush" Value="#f0be4a" />
        </Style>
        <Style Selector="Button.SettingsButton:pointerover /template/ Image#PART_Icon">
            <Setter Property="Opacity" Value="1.0" />
        </Style>
        <Style Selector="Button.SettingsButton:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.08)" />
        </Style>
        <Style Selector="Button.SettingsButton:pressed /template/ Border#PART_Border">
            <Setter Property="Background" Value="#551A1028" />
            <Setter Property="BorderBrush" Value="#CCf0be4a" />
        </Style>
        <Style Selector="Button.SettingsButton:pressed /template/ Image#PART_Icon">
            <Setter Property="Opacity" Value="0.7" />
        </Style>
        <Style Selector="Button.SettingsButton:pressed">
            <Setter Property="RenderTransform" Value="scale(0.92)" />
        </Style>

        <Style Selector="Border.InfoPanel">
            <Setter Property="Background" Value="#801A1028" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#f0be4a" />
            <Setter Property="BoxShadow" Value="0 4 20 0 #50000000" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2" />
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2" />
                </Transitions>
            </Setter>
        </Style>

        <!-- Scrollbar theme overrides -->
        <Style Selector="ScrollViewer.ChangelogScroll">
            <Style.Resources>
                <SolidColorBrush x:Key="ScrollBarThumbFill" Color="#99f0be4a" />
                <SolidColorBrush x:Key="ScrollBarThumbFillPointerOver" Color="#f0be4a" />
                <SolidColorBrush x:Key="ScrollBarThumbFillPressed" Color="#DDf0be4a" />
                <SolidColorBrush x:Key="ScrollBarTrackFill" Color="Transparent" />
                <SolidColorBrush x:Key="ScrollBarTrackFillPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="ScrollBarPanningThumbBackground" Color="#99f0be4a" />
                <x:Double x:Key="ScrollBarSize">8</x:Double>
            </Style.Resources>
            <Setter Property="Padding" Value="0,0,2,0" />
        </Style>
        <Style Selector="ScrollViewer.ChangelogScroll /template/ ScrollBar:vertical">
            <Setter Property="Width" Value="8" />
            <Setter Property="Margin" Value="0,4,3,4" />
        </Style>
        <Style Selector="ScrollViewer.ChangelogScroll /template/ ScrollBar /template/ Thumb /template/ Border">
            <Setter Property="Background" Value="#99f0be4a" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="ScrollViewer.ChangelogScroll /template/ ScrollBar /template/ Thumb:pointerover /template/ Border">
            <Setter Property="Background" Value="#f0be4a" />
        </Style>
        <Style Selector="ScrollViewer.ChangelogScroll /template/ ScrollBar /template/ Thumb:pressed /template/ Border">
            <Setter Property="Background" Value="#DDf0be4a" />
        </Style>
        <Style Selector="ScrollViewer.ChangelogScroll /template/ ScrollBar /template/ RepeatButton">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </Window.Styles>

    <Grid>
        <Panel>
            <Image Source="{Binding BackgroundImageSource}"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch" />
            <Rectangle Fill="#25000000" />
        </Panel>

        <Rectangle x:Name="titleBarArea"
                   Height="32"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Stretch"
                   Fill="Transparent" />

        <Grid VerticalAlignment="Top" ZIndex="10">

            <StackPanel HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="20,40,0,0"
                        Spacing="10">

                <Button Classes="SocialButton"
                        Command="{Binding OpenYoutubeCommand}"
                        ToolTip.Tip="YouTube">
                    <Panel>
                        <Path Data="{StaticResource YouTubeIconPath}"
                              Fill="White"
                              Width="22" Height="22"
                              Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Margin="0,5,0,0" />
                    </Panel>
                </Button>

                <Button Classes="SocialButton"
                        Command="{Binding OpenDiscordCommand}"
                        ToolTip.Tip="Discord">
                    <Panel>
                        <Path Data="{StaticResource DiscordIconPath}"
                              Fill="White"
                              Width="22" Height="22"
                              Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              Margin="0,5,0,0" />
                    </Panel>
                </Button>

                <Button Classes="SocialButton"
                        Command="{Binding OpenXCommand}"
                        ToolTip.Tip="X">
                    <Panel>
                        <Path Data="{StaticResource XIconPath}"
                              Fill="White"
                              Width="22" Height="22"
                              Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Panel>
                </Button>

                <Button Classes="SocialButton"
                        Command="{Binding OpenFacebookCommand}"
                        ToolTip.Tip="Facebook">
                    <Panel>
                        <Path Data="{StaticResource FacebookIconPath}"
                              Fill="White"
                              Width="22" Height="22"
                              Stretch="Uniform"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Panel>
                </Button>

            </StackPanel>

            <Image x:Name="logoImage"
                   Source="{Binding LogoImageSource}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Width="203" Height="108"
                   Margin="0,40,20,0" />
        </Grid>

        <Border HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Width="420" Height="220"
                Margin="20,0,0,20"
                Classes="InfoPanel"
                Padding="12"
                ZIndex="1">
            <Grid RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Changelog"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#f0be4a"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12" />

                <ScrollViewer Grid.Row="1"
                              Classes="ChangelogScroll"
                              VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Disabled"
                              AllowAutoHide="False">
                    <SelectableTextBlock utils:ChangelogTextHelper.Source="{Binding ChangelogLines}"
                                         TextWrapping="Wrap"
                                         Padding="0,0,6,0"
                                         LineHeight="20"
                                         SelectionBrush="#50f0be4a" />
                </ScrollViewer>
            </Grid>
        </Border>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,20,20"
                    Spacing="10">

            <Button Classes="SettingsButton"
                    Command="{Binding SettingsButtonClickedCommand}"
                    ToolTip.Tip="Options"
                    VerticalAlignment="Center" />

            <Grid Width="280" Height="90">
                <ProgressBar IsVisible="{Binding IsProgressOverlayVisible}"
                             Value="{Binding ProgressBarValue}"
                             IsIndeterminate="{Binding IsProgressBarIndeterminate}"
                             Height="90" Width="280"
                             Theme="{StaticResource TexturedProgressBar}"
                             HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

                <Grid IsVisible="{Binding IsProgressOverlayVisible}"
                      Width="280" Height="90"
                      ColumnDefinitions="*,*">

                    <TextBlock Grid.Column="0"
                               Text="{Binding ProgressPercentageText}"
                               FontSize="32" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" />

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="-20,0,15,0"
                                Spacing="2">
                        <TextBlock Text="{Binding DownloadSpeedText}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Left" TextAlignment="Left" />
                        <TextBlock Text="{Binding DownloadStatusText}"
                                   FontSize="14" FontWeight="Medium"
                                   Foreground="#E0FFFFFF"
                                   HorizontalAlignment="Left" TextAlignment="Left" />
                    </StackPanel>
                </Grid>

                <Button Content="{Binding ActionButtonText}"
                        Background="{Binding ActionButtonBackground}"
                        Command="{Binding ActionButtonClickedCommand}"
                        IsEnabled="{Binding IsActionButtonEnabled}"
                        IsVisible="{Binding !IsProgressOverlayVisible}"
                        Theme="{StaticResource ActionButton}"
                        Width="280" Height="90"
                        FontSize="28" FontWeight="Bold"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Cursor="Hand" />
            </Grid>
        </StackPanel>
    </Grid>
</Window>
